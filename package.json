{
  "name": "@githooked/cli",
  "version": "0.1.0",
  "description": "Catch bad code before you push using the coding agent you already have.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/githooked/githooked.git"
  },
  "homepage": "https://githooked.github.io/githooked/",
  "bugs": {
    "url": "https://github.com/githooked/githooked/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "git",
    "hooks",
    "codex",
    "code-review",
    "security"
  ],
  "type": "module",
  "bin": {
    "git-hooked": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "guide-packs",
    "docs/GUIDE_PACKS.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run tests",
    "test:examples": "vitest run tests/examples.test.ts",
    "test:hook-managers": "cross-env GIT_HOOKED_MANAGER_INTEGRATION=1 vitest run tests/hook-managers.test.ts",
    "test:codex": "vitest run tests/codex.test.ts",
    "dev": "tsx src/cli/index.ts",
    "dev:web": "vite web --host 0.0.0.0",
    "build:web": "vite build web",
    "verify": "npm test && npm run typecheck && npm run lint && npm run build && npm run build:web",
    "prepack": "npm run verify"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "lucide": "^1.24.0",
    "minimatch": "^10.0.3",
    "yaml": "^2.8.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.16.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.0"
  }
}
