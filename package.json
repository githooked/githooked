{
  "name": "git-hooked",
  "version": "0.1.0",
  "description": "Catch bad code before you push using the coding agent you already have.",
  "type": "module",
  "bin": { "git-hooked": "dist/cli/index.js" },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "dev": "tsx src/cli/index.ts",
    "dev:web": "vite web --host 0.0.0.0",
    "build:web": "vite build web"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "minimatch": "^10.0.3",
    "yaml": "^2.8.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.16.0",
    "eslint": "^9.31.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.0"
  }
}
